# (선택) 앱 코드용. sitemap/rss/robots는 public/ 폴더 파일을 수정해 도메인 맞춤
VITE_SITE_URL=https://tap-tap828288.vercel.app

VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash
# 번역(Edge Function 호출)·공유 링크 저장에 필요 — Supabase 대시보드 > Settings > API
# Vercel 배포 시: .env는 올라가지 않음 → Vercel Dashboard > Environment Variables에 아래 키들을 동일 이름으로 추가 후 Redeploy
VITE_SUPABASE_URL=https://xxxx.supabase.co
# 아래 둘 중 하나만 있어도 됩니다 (anon public 키)
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Image sourcing (supported prefixes: NEXT_PUBLIC_*, VITE_*)
NEXT_PUBLIC_GIPHY_API_KEY=
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=

# --- Supabase Edge Function 시크릿 (Dashboard / supabase secrets set — Vite .env 아님) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TEMPERATURE=0.64   # 낮출수록 보통 더 빠르고 짧게 나옴
# OPENAI_MAX_TOKENS=1000      # 짧게 줄이면 응답 시간↓ (더 긴 글이 필요하면 1400~1800)
# OPENAI_JSON_MODE=true       # 미지원 모델이면 false
